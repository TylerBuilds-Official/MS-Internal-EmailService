# ── Microsoft Entra ID (Azure AD) app registration ───────────────────────────
# Register an app with the Microsoft Graph *application* permissions
# `Mail.Send` and `User.Read.All` (admin-consented), then copy its values here.
# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# Application (client) ID of the app registration.
CLIENT_ID=00000000-0000-0000-0000-000000000000

# Directory (tenant) ID of the Microsoft 365 tenant.
TENANT_ID=00000000-0000-0000-0000-000000000000

# A client secret generated for the app registration.
CLIENT_SECRET=your-client-secret-value

# Object ID (GUID) of the mailbox that mail is sent *from*.
# Use a dedicated service account — NOT a personal user.
SERVICE_USER_ID=00000000-0000-0000-0000-000000000000

# Organization display name, shown in recipient-validation error messages.
COMPANY_NAME=Your Company Name

# ── API ───────────────────────────────────────────────────────────────────────
# Shared secret required in the `X-API-Key` header on POST /send.
# Generate a long random value, e.g.  python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=generate-a-long-random-secret

# Comma-separated allowed CORS origins. Defaults to "*" if unset.
CORS_ORIGINS=*
